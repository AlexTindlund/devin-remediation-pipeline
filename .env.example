# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).

# ── Required ──────────────────────────────────────────────────────────────
# Your Devin personal API key. Looks like: apk_user_xxxxxxxxxxxxxxxx
DEVIN_API_KEY=

# ── Target ────────────────────────────────────────────────────────────────
# The fork the pipeline remediates, and the label that marks issues for Devin.
GITHUB_REPO=AlexTindlund/superset
TRIGGER_LABEL=Tasks for devin

# ── Optional ──────────────────────────────────────────────────────────────
# A GitHub token (public_repo / read:issues scope) lifts the 60-req/hr
# unauthenticated rate limit when listing issues. Recommended, not required.
GITHUB_TOKEN=

# Shared secret for GitHub webhook signature verification (X-Hub-Signature-256).
# If set, unsigned or mis-signed webhook deliveries are rejected. Leave blank
# to accept unsigned deliveries (fine for local/simulated triggering).
WEBHOOK_SECRET=

# ── Tunables ──────────────────────────────────────────────────────────────
POLL_INTERVAL_SEC=30     # how often the poller checks each in-flight session
DEVIN_MAX_ACU=10         # per-session ACU ceiling (cost guardrail)
